<Window x:Name="Editor1" x:Class="BobMapper.Editor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BobMapper"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:model="clr-namespace:BobMapper.Model"
        xmlns:object="clr-namespace:BobMapper.Model.MapObjects"
        xmlns:vm="clr-namespace:BobMapper.ViewModel"
        xmlns:s="clr-namespace:System;assembly=netstandard"
        xmlns:services="clr-namespace:BobMapper.Services"
        xmlns:uc="clr-namespace:BobMapper.View.UserControls"
        xmlns:ctrls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework" d:DataContext="{d:DesignInstance Type=vm:EditorViewModel}"
        mc:Ignorable="d"
        Background="LightGray"
        Closing="TryClose"
        Title="Editor" Height="720" Width="1280" WindowState="Maximized">

    <Window.Resources>
        <ObjectDataProvider x:Key="Tools" ObjectType="{x:Type s:Enum}" MethodName="GetValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type Type="{x:Type local:Tools}"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="TextureTypes" ObjectType="{x:Type s:Enum}" MethodName="GetValues">
            <ObjectDataProvider.MethodParameters>
                <x:Type Type="{x:Type local:Tools}"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <services:EnumBoolConverter x:Key="EnumBoolConvert"/>
        <ctrls:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <s:Boolean x:Key="True">True</s:Boolean>
        <s:Boolean x:Key="False">False</s:Boolean>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteObjectCommand}"/>
        <KeyBinding Key="Up" Modifiers="Shift" Command="{Binding MoveViewportCommand}" 
            CommandParameter="Up"/>
        <KeyBinding Key="Right" Modifiers="Shift" Command="{Binding MoveViewportCommand}" 
            CommandParameter="Right"/>
        <KeyBinding Key="Down" Modifiers="Shift" Command="{Binding MoveViewportCommand}" 
            CommandParameter="Down"/>
        <KeyBinding Key="Left" Modifiers="Shift" Command="{Binding MoveViewportCommand}" 
            CommandParameter="Left"/>
        <KeyBinding Key="C" Modifiers="Shift" Command="{Binding MoveViewportCommand}"
            CommandParameter="Reset"/>
        <KeyBinding Key="Subtract" Modifiers="Shift" Command="{Binding ScaleViewportCommand}"
                    CommandParameter="Out"/>
        <KeyBinding Key="Add" Modifiers="Shift" Command="{Binding ScaleViewportCommand}"
                    CommandParameter="In"/>
        <KeyBinding Key="Multiply" Modifiers="Shift" Command="{Binding ScaleViewportCommand}"
                    CommandParameter="Reset"/>
        <KeyBinding Key="S" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static local:Tools.Select}"/>
        <KeyBinding Key="E" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static local:Tools.Move}"/>
        <KeyBinding Key="R" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static local:Tools.Rotate}"/>
        <KeyBinding Key="W" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.AddWall}"/>
        <KeyBinding Key="O" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.AddProp}"/>
        <KeyBinding Key="N" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.AddNPC}"/>
        <KeyBinding Key="P" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.AddPathPoint}"/>
        <KeyBinding Key="F" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.ChangeFloor}"/>
        <KeyBinding Key="R" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.Rotate}"/>
        <KeyBinding Key="M" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.AddMisc}"/>
        <KeyBinding Key="D" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.AddDoor}"/>
        <KeyBinding Key="L" Command="{Binding SelectToolCommand}"
            CommandParameter="{x:Static local:Tools.AddLoot}"/>
    </Window.InputBindings>

    <Grid x:Name="WindowGrid">
        <DockPanel Background="SlateGray">
            <Menu DockPanel.Dock="Top" Width="auto" Height="20">
                <MenuItem Header="File">
                    <MenuItem Header="New Project"/>
                    <MenuItem Header="Open Project"/>
                    <Separator/>
                    <MenuItem Header="Save" Command="{Binding SaveCommand}" CommandParameter="{StaticResource False}"/>
                    <MenuItem Header="Save as" Command="{Binding SaveCommand}" CommandParameter="{StaticResource True}"/>
                    <MenuItem Header="Exit"/>
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="Expand or Contract Map" IsEnabled="False"/>
                    <MenuItem Header="Object list" IsEnabled="False"/>
                    <Separator/>
                    <MenuItem Header="Prefrences" IsEnabled="False"/>
                </MenuItem>
                <MenuItem Header="Compile">
                    <MenuItem Header="Compile to" Command="{Binding CompileCommand}" CommandParameter="{StaticResource True}"></MenuItem>
                    <MenuItem Header="Inject" IsEnabled="False"></MenuItem>
                    <MenuItem Header="Inject and Play" IsEnabled="False"></MenuItem>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem Header="Shortcuts"/>
                    <MenuItem Header="About"/>
                </MenuItem>
            </Menu>
            <Menu DockPanel.Dock="Left" Width="auto" Height="auto" Name="ToolDrawer">
                <MenuItem Header="Select" Name="SelectTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.Select}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/SelectionTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Move" Name="MoveTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.Move}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/MoveTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Rotate" Name="RotateTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.Rotate}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/RotateTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator></Separator>
                <MenuItem Header="Draw Wall" Name="AddWallTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.AddWall}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/AddWallTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Place Prop" Name="AddPropTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.AddProp}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/AddPropTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Add NPC" Name="AddNPCTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.AddNPC}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/AddNPCTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Add Path" Name="AddPathTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.AddPathPoint}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/AddPathTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Paint Floor" Name="ChangeFloorTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.ChangeFloor}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/AddFloorTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Add Misc" Name="AddMiscTool"
                          Command="{Binding SelectToolCommand}" 
                          CommandParameter="{x:Static local:Tools.AddMisc}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/AddMiscTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Add Door" Name="AddDoorTool"
                    Command="{Binding SelectToolCommand}" 
                    CommandParameter="{x:Static local:Tools.AddDoor}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/AddMiscTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Add Loot" Name="AddLootTool"
                     Command="{Binding SelectToolCommand}" 
                     CommandParameter="{x:Static local:Tools.AddLoot}">
                    <MenuItem.Icon>
                        <Image Source="/Resources/UI/AddMiscTool.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Menu.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </Menu.ItemsPanel>
            </Menu>
            <StackPanel DockPanel.Dock="Right" Width="300" Height="auto" HorizontalAlignment="Right" Background="LightGray">
                <StackPanel Orientation="Horizontal">
                    <Expander IsExpanded="True">
                        <WrapPanel Orientation="Horizontal" Width="300">
                            <CheckBox Content="Walls" IsChecked="{Binding CurrentLayerData.WallsVisible}" Margin="10,5,10,10" Width="100"/>
                            <CheckBox Content="Props" IsChecked="{Binding CurrentLayerData.PropsVisible}" Margin="10,5,10,10" Width="100"/>
                            <CheckBox Content="NPCs" IsChecked="{Binding CurrentLayerData.NPCsVisible}" Margin="10,5,10,10" Width="100"/>
                            <CheckBox Content="Paths" IsChecked="{Binding CurrentLayerData.PathPointsVisible}" Margin="10,5,10,10" Width="100"/>
                            <CheckBox Content="Floor" IsChecked="{Binding CurrentLayerData.FloorsVisible}" Margin="10,5,10,10" Width="100"/>
                            <CheckBox Content="Miscs" IsChecked="{Binding CurrentLayerData.MiscsVisible}" Margin="10,5,10,10" Width="100"/>
                            <CheckBox Content="Doors" IsChecked="{Binding CurrentLayerData.DoorsVisible}" Margin="10,5,10,10" Width="100"/>
                            <CheckBox Content="Loots" IsChecked="{Binding CurrentLayerData.LootsVisible}" Margin="10,5,10,10" Width="100"/>
                        </WrapPanel>
                    </Expander>
                    <Label>Layers</Label>
                </StackPanel>
                <Separator Foreground="Black"></Separator>

                <StackPanel Orientation="Horizontal">
                    <Expander IsExpanded="True">
                        <WrapPanel Orientation="Horizontal">
                            <ContentControl Content="{Binding CurrentSelections.SelectedProp}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type object:Prop}">
                                        <WrapPanel Width="300">
                                            <Label Width="170">X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                                 PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Rotation</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Rotation, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                                PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Asset</Label>
                                            <Image Source="{Binding PropTexture}" MaxHeight="100" MaxWidth="100"/>
                                            <Label Content="{Binding PropTexture}"/>
                                            <Button Content="Set to selected asset">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="Click">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.SetObjectTextureCommand, 
                                                        RelativeSource={RelativeSource AncestorType=Expander}}" CommandParameter="PropTexture" />
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Button>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                            <ContentControl Content="{Binding CurrentSelections.SelectedLoot}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type object:Loot}">
                                        <WrapPanel Width="300">
                                            <Label Width="170">X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Rotation</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Rotation, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Asset</Label>
                                            <Image Source="{Binding Texture}" MaxHeight="100" MaxWidth="100"/>
                                            <Label Content="{Binding Texture}"/>
                                            <Button Content="Set to selected asset">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="Click">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.SetObjectTextureCommand, 
                                                           RelativeSource={RelativeSource AncestorType=Expander}}" CommandParameter="LootTexture" />
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Button>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                            <ContentControl Content="{Binding CurrentSelections.SelectedMisc}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type object:Misc}">
                                        <WrapPanel Width="300">
                                            <Label Width="170">X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Type</Label>
                                            <Image Source="{Binding Texture}" MaxHeight="100" MaxWidth="100"/>
                                            <Label Content="Type"/>
                                            <ComboBox SelectedItem="{Binding Type}" ItemsSource="{Binding MiscTypeValues}">

                                            </ComboBox>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                            <ContentControl Content="{Binding CurrentSelections.SelectedDoor}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type object:Door}">
                                        <WrapPanel Width="300">
                                            <Label Width="170">Point 1 - X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Point1.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Point 1 - Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Point1.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Point 2 - X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Point2.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Point 2 - Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Point2.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Texture</Label>
                                            <Image Source="{Binding Texture1}" MaxHeight="100" MaxWidth="100"/>
                                            <Button Content="Set to selected asset">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="Click">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.SetObjectTextureCommand, 
                                                            RelativeSource={RelativeSource AncestorType=Expander}}" CommandParameter="DoorTexture" />
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Button>
                                            <Label Content="{Binding Texture1}"/>
                                            <CheckBox Content="Locked" Width="250" IsChecked="{Binding Locked}"/>
                                            <CheckBox Content="Permanent Lock" Width="250" IsChecked="{Binding PermLocked}"/>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                            <ContentControl Content="{Binding CurrentSelections.SelectedWall}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type object:Wall}">
                                        <WrapPanel Width="300">
                                            <Label Width="170">Point 1 - X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Point1.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Point 1 - Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Point1.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Point 2 - X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Point2.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Point 2 - Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Point2.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Left Texture</Label>
                                            <Image Source="{Binding Texture1}" MaxHeight="100" MaxWidth="100"/>
                                            <Button Content="Set to selected asset">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="Click">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.SetObjectTextureCommand, 
                                                        RelativeSource={RelativeSource AncestorType=Expander}}" CommandParameter="WallTexture1" />
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Button>
                                            <Label Content="{Binding Texture1}"/>
                                            <Label Width="170">Right Texture</Label>
                                            <Image Source="{Binding Texture2}" MaxHeight="100" MaxWidth="100"/>
                                            <Button Content="Set to selected asset">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="Click">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.SetObjectTextureCommand, 
                                                            RelativeSource={RelativeSource AncestorType=Expander}}" CommandParameter="WallTexture2" />
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Button>
                                            <Label Content="{Binding Texture2}"/>
                                            <Label Width="170">Wall Type:</Label>
                                            <ComboBox ItemsSource="{Binding WallTypeValues}" SelectedItem="{Binding Type}"/>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                            <ContentControl Content="{Binding CurrentSelections.SelectedNPC}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type object:NPC}">
                                        <WrapPanel Width="300">
                                            <Label Width="170">X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Rotation</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Rotation, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Starting Path Point (Id)</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding FirstPathPointId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                                    PreviewTextInput="TextBox_PreviewTextInput"
                                            PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Asset</Label>
                                            <Image Source="{Binding Texture}" MaxHeight="100" MaxWidth="100"/>
                                            <ComboBox ItemsSource="{Binding NPCTypeValues}" SelectedItem="{Binding Type}" Width="200" MinHeight="30"/>
                                            <CheckBox Content="Has loot attached" Width="250" IsChecked="{Binding AttachLoot}"/>
                                            <CheckBox Content="Has main loot attached" Width="250" IsChecked="{Binding AttachMainLoot}"/>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                            <ContentControl Content="{Binding CurrentSelections.SelectedPathPoint}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type object:PathPoint}">
                                        <WrapPanel Width="300">
                                            <Label Width="170">Path point Id</Label>
                                            <Label Width="100" Height="20" Content="{Binding Id}"></Label>
                                            <Label Width="170">Next path point Id</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding ConnectToId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">X Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedXPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Y Coordinate</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Coordinates.SnappedYPos, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Rotation</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Rotation, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                            <Label Width="170">Duration</Label>
                                            <TextBox Width="100" Height="20" Text="{Binding Duration, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            PreviewTextInput="TextBox_PreviewTextInput"
                                                     PreviewKeyDown="TextBox_PreviewKeyDown"></TextBox>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                        </WrapPanel>
                    </Expander>
                    <Label>Properties</Label>
                </StackPanel>
                <Separator Foreground="Black"/>
                <StackPanel Orientation="Horizontal">
                    <Expander IsExpanded="True">
                        <WrapPanel Orientation="Horizontal" Width="300">
                            <Label Width="170">Selected Texture</Label>
                            <Border BorderBrush="Black" BorderThickness="1">
                                <Image Source="{Binding CurrentSelections.SelectedTexture}" Height="100" Width="100"/>
                            </Border>
                            <Label Width="250" Content="{Binding CurrentSelections.SelectedTexture}"></Label>

                            <ComboBox Width="250" Height="20" Margin="20" ItemsSource="{Binding CurrentMap.TextureTypeValues}" SelectedItem="{Binding CurrentSelections.SelectedTextureType}">
                            </ComboBox>
                            <ScrollViewer Width="300" Height="740">
                                <ItemsControl ItemsSource="{Binding CurrentSelections.CurrentTextureSet}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding}" MaxHeight="100" MaxWidth="100" Margin="10">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="MouseLeftButtonDown">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.SetTextureCommand, 
                                                        RelativeSource={RelativeSource AncestorType=Expander}}" CommandParameter="{Binding}" />
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Image>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                        </WrapPanel>
                    </Expander>
                    <Label>Asset Gallery</Label>
                </StackPanel>
            </StackPanel>
            <!-- BAD CANVAS CODE AHEAD -->
            <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center" Background="Gray" Focusable="False"
                          PreviewMouseDown="ClickEmpty" x:Name="ScrollPlane">
                <Canvas HorizontalAlignment="Center" VerticalAlignment="Center" Width="0" Height="0" 
                    RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleY="{Binding CurrentViewportData.ZoomY}" ScaleX="{Binding CurrentViewportData.ZoomX}"/>
                            <TranslateTransform X="{Binding CurrentViewportData.CameraX}" Y="{Binding CurrentViewportData.CameraY}"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>
                    <!-- Might have to be offset -->
                    <!-- TODO: Add Texture 2-->
                    <ItemsControl ItemsSource="{Binding CurrentFloors}" Canvas.Left="{Binding CurrentViewportData.ViewOffsetX}" Canvas.Top="{Binding CurrentViewportData.ViewOffsetY}"
                                  Visibility="{Binding CurrentLayerData.FloorsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding .}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type object:Floor}">
                                            <Image Source="{Binding Texture1}" Width="64" Height="64" RenderTransformOrigin="0.5,0.5">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="MouseLeftButtonDown">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.ClickObjectCommand, 
                                                        RelativeSource={RelativeSource AncestorType=Canvas}}" CommandParameter="{Binding}" />
                                                    </i:EventTrigger>
                                                    <i:EventTrigger EventName="MouseRightButtonDown">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.RightClickObjectCommand, 
                                                            RelativeSource={RelativeSource AncestorType=Canvas}}" CommandParameter="{Binding}"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                                <Image.RenderTransform>
                                                    <ScaleTransform ScaleX="{Binding VisualScaleX}" ScaleY="{Binding VisualScaleY}"/>
                                                </Image.RenderTransform>
                                            </Image>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Width="{Binding CurrentMap.Width, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding CurrentProps}" Visibility="{Binding CurrentLayerData.PropsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:CenteringCanvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Coordinates.XPos}" />
                                <Setter Property="Canvas.Top" Value="{Binding Coordinates.YPos}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type object:Prop}">
                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleY="-1"/>
                                            <RotateTransform Angle="{Binding Rotation}"/>
                                        </TransformGroup>
                                    </Grid.RenderTransform>
                                    <Image Source="{Binding PropTexture}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonDown">
                                                <i:InvokeCommandAction Command="{Binding DataContext.ClickObjectCommand, 
                                                RelativeSource={RelativeSource AncestorType=ScrollViewer}}" CommandParameter="{Binding}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Image>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding CurrentLoots}" Visibility="{Binding CurrentLayerData.LootsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:CenteringCanvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Coordinates.XPos}" />
                                <Setter Property="Canvas.Top" Value="{Binding Coordinates.YPos}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type object:Loot}">
                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleY="-1"/>
                                            <RotateTransform Angle="{Binding Rotation}"/>
                                        </TransformGroup>
                                    </Grid.RenderTransform>
                                    <Image Source="{Binding Texture}" Stretch="None">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="MouseLeftButtonDown">
                                                    <i:InvokeCommandAction Command="{Binding DataContext.ClickObjectCommand, 
                                                RelativeSource={RelativeSource AncestorType=ScrollViewer}}" CommandParameter="{Binding}" />
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                    </Image>
                                    <Image Source="/Resources/MiscTextures/LootGlare.png" IsHitTestVisible="False" Opacity="0.7"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding CurrentWalls}" Visibility="{Binding CurrentLayerData.WallsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type object:Wall}">
                                <Line StrokeThickness="{Binding Width}" X1="{Binding Point1.XPos}" Y1="{Binding Point1.YPos}"
                                      X2="{Binding Point2.XPos}" Y2="{Binding Point2.YPos}" Fill="Beige" Stroke="Beige">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonDown">
                                            <i:InvokeCommandAction Command="{Binding DataContext.ClickObjectCommand, 
                                                RelativeSource={RelativeSource AncestorType=Canvas}}" CommandParameter="{Binding}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Line>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas></Canvas>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding CurrentDoors}" Visibility="{Binding CurrentLayerData.DoorsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type object:Door}">
                                <Canvas>
                                    <Line StrokeThickness="10" X1="{Binding Point1.XPos}" Y1="{Binding Point1.YPos}"
                                X2="{Binding Point2.XPos}" Y2="{Binding Point2.YPos}" Fill="Brown" Stroke="Brown">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonDown">
                                                <i:InvokeCommandAction Command="{Binding DataContext.ClickObjectCommand, 
                                            RelativeSource={RelativeSource AncestorType=ScrollViewer}}" CommandParameter="{Binding}"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Line>
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas></Canvas>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding CurrentNPCs}" Visibility="{Binding CurrentLayerData.NPCsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:CenteringCanvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Coordinates.XPos}" />
                                <Setter Property="Canvas.Top" Value="{Binding Coordinates.YPos}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type object:NPC}">
                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleY="-1"/>
                                            <RotateTransform Angle="{Binding Rotation}"/>
                                        </TransformGroup>
                                    </Grid.RenderTransform>
                                    <Canvas>
                                        <Image Source="{Binding Texture}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="MouseLeftButtonDown">
                                                    <i:InvokeCommandAction Command="{Binding DataContext.ClickObjectCommand, 
                                                RelativeSource={RelativeSource AncestorType=ScrollViewer}}" CommandParameter="{Binding}" />
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </Image>
                                        <Image Source="/Resources/MiscTextures/LootGlare.png" Visibility="{Binding AttachLoot, Converter={StaticResource BooleanToVisibilityConverter}}" IsHitTestVisible="False"/>
                                        <Image Source="/Resources/MiscTextures/MainLoot.png" Visibility="{Binding AttachMainLoot, Converter={StaticResource BooleanToVisibilityConverter}}" IsHitTestVisible="False"/>
                                    </Canvas>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding CurrentPathPoints}" Visibility="{Binding CurrentLayerData.PathPointsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type object:PathPoint}">
                                <Canvas>
                                    <Line StrokeDashArray="4 2" StrokeThickness="2" Stroke="White"
                                          X1="0" 
                                          Y1="0"
                                          X2="{Binding ConnectionDeltaX, UpdateSourceTrigger=PropertyChanged}" 
                                          Y2="{Binding ConnectionDeltaY, UpdateSourceTrigger=PropertyChanged}">
                                    </Line>
                                    <Ellipse Width="10" Height="10" Stroke="White" Fill="White">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform X="-5" Y="-5"/>
                                        </Ellipse.RenderTransform>
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonDown">
                                                <i:InvokeCommandAction Command="{Binding DataContext.ClickObjectCommand, 
                                                RelativeSource={RelativeSource AncestorType=Grid}}" CommandParameter="{Binding}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Ellipse>
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:CenteringCanvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Coordinates.XPos}" />
                                <Setter Property="Canvas.Top" Value="{Binding Coordinates.YPos}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding CurrentMiscs}" Visibility="{Binding CurrentLayerData.MiscsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:CenteringCanvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Coordinates.XPos}" />
                                <Setter Property="Canvas.Top" Value="{Binding Coordinates.YPos}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type object:Misc}">
                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleY="-1"/>
                                        </TransformGroup>
                                    </Grid.RenderTransform>
                                    <Image Source="{Binding Texture}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonDown">
                                                <i:InvokeCommandAction Command="{Binding DataContext.ClickObjectCommand, 
                                RelativeSource={RelativeSource AncestorType=ScrollViewer}}" CommandParameter="{Binding}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Image>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <uc:MoveGizmo x:Name="PropGizmo" Visibility="{Binding CurrentGizmoData.PropGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Canvas.Left="{Binding CurrentSelections.SelectedProp.Coordinates.XPos}"
                                  Canvas.Top="{Binding CurrentSelections.SelectedProp.Coordinates.YPos}"
                                  DragCommand="{Binding CurrentGizmoData.PropGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                        </uc:MoveGizmo>
                    <uc:MoveGizmo x:Name="NPCGizmo" Visibility="{Binding CurrentGizmoData.NPCGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Canvas.Left="{Binding CurrentSelections.SelectedNPC.Coordinates.XPos}"
                        Canvas.Top="{Binding CurrentSelections.SelectedNPC.Coordinates.YPos}"
                            DragCommand="{Binding CurrentGizmoData.NPCGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                    </uc:MoveGizmo>
                    <uc:MoveGizmo x:Name="WallGizmo1" Visibility="{Binding CurrentGizmoData.WallGizmosEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.Left="{Binding CurrentSelections.SelectedWall.Point1.XPos}"
                    Canvas.Top="{Binding CurrentSelections.SelectedWall.Point1.YPos}"
                    DragCommand="{Binding CurrentGizmoData.WallGizmo1MovedCommand}" RenderTransformOrigin="0.5,0.5">
                    </uc:MoveGizmo>
                    <uc:MoveGizmo x:Name="WallGizmo2" Visibility="{Binding CurrentGizmoData.WallGizmosEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.Left="{Binding CurrentSelections.SelectedWall.Point2.XPos}"
                    Canvas.Top="{Binding CurrentSelections.SelectedWall.Point2.YPos}"
                    DragCommand="{Binding CurrentGizmoData.WallGizmo2MovedCommand}" RenderTransformOrigin="0.5,0.5">
                    </uc:MoveGizmo>
                    <uc:MoveGizmo x:Name="DoorGizmo1" Visibility="{Binding CurrentGizmoData.DoorGizmosEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.Left="{Binding CurrentSelections.SelectedDoor.Point1.XPos}"
                    Canvas.Top="{Binding CurrentSelections.SelectedDoor.Point1.YPos}"
                    DragCommand="{Binding CurrentGizmoData.DoorGizmo1MovedCommand}" RenderTransformOrigin="0.5,0.5">
                    </uc:MoveGizmo>
                    <uc:MoveGizmo x:Name="DoorGizmo2" Visibility="{Binding CurrentGizmoData.DoorGizmosEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.Left="{Binding CurrentSelections.SelectedDoor.Point2.XPos}"
                    Canvas.Top="{Binding CurrentSelections.SelectedDoor.Point2.YPos}"
                    DragCommand="{Binding CurrentGizmoData.DoorGizmo2MovedCommand}" RenderTransformOrigin="0.5,0.5">
                    </uc:MoveGizmo>
                    <uc:MoveGizmo x:Name="LootGizmo" Visibility="{Binding CurrentGizmoData.LootGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.Left="{Binding CurrentSelections.SelectedLoot.Coordinates.XPos}"
                    Canvas.Top="{Binding CurrentSelections.SelectedLoot.Coordinates.YPos}"
                    DragCommand="{Binding CurrentGizmoData.LootGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                    </uc:MoveGizmo>
                    <uc:MoveGizmo x:Name="MiscGizmo" Visibility="{Binding CurrentGizmoData.MiscGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.Left="{Binding CurrentSelections.SelectedMisc.Coordinates.XPos}"
                    Canvas.Top="{Binding CurrentSelections.SelectedMisc.Coordinates.YPos}"
                    DragCommand="{Binding CurrentGizmoData.MiscGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                    </uc:MoveGizmo>
                    <uc:MoveGizmo x:Name="PathPointGizmo" Visibility="{Binding CurrentGizmoData.PathPointGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.Left="{Binding CurrentSelections.SelectedPathPoint.Coordinates.XPos}"
                    Canvas.Top="{Binding CurrentSelections.SelectedPathPoint.Coordinates.YPos}"
                    DragCommand="{Binding CurrentGizmoData.PathPointGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                    </uc:MoveGizmo>
                    <local:CenteringCanvas>
                    <uc:RotateGizmo x:Name="PropRotateGizmo" Visibility="{Binding CurrentGizmoData.PropRotateGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.Left="{Binding CurrentSelections.SelectedProp.Coordinates.XPos}"
                    Canvas.Top="{Binding CurrentSelections.SelectedProp.Coordinates.YPos}"
                    DragCommand="{Binding CurrentGizmoData.PropRotateGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                        <uc:RotateGizmo.RenderTransform>
                            <TransformGroup>
                                <RotateTransform Angle="{Binding CurrentSelections.SelectedProp.Rotation}"/>
                            </TransformGroup>
                        </uc:RotateGizmo.RenderTransform>
                    </uc:RotateGizmo>
                    </local:CenteringCanvas>
                    <local:CenteringCanvas>
                        <uc:RotateGizmo x:Name="NPCRotateGizmo" Visibility="{Binding CurrentGizmoData.NPCRotateGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Canvas.Left="{Binding CurrentSelections.SelectedNPC.Coordinates.XPos}"
                            Canvas.Top="{Binding CurrentSelections.SelectedNPC.Coordinates.YPos}"
                            DragCommand="{Binding CurrentGizmoData.NPCRotateGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                            <uc:RotateGizmo.RenderTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="{Binding CurrentSelections.SelectedNPC.Rotation}"/>
                                </TransformGroup>
                            </uc:RotateGizmo.RenderTransform>
                        </uc:RotateGizmo>
                    </local:CenteringCanvas>
                    <local:CenteringCanvas>
                        <uc:RotateGizmo x:Name="PathPointRotateGizmo" Visibility="{Binding CurrentGizmoData.PathPointRotateGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Canvas.Left="{Binding CurrentSelections.SelectedPathPoint.Coordinates.XPos}"
                            Canvas.Top="{Binding CurrentSelections.SelectedPathPoint.Coordinates.YPos}"
                            DragCommand="{Binding CurrentGizmoData.PathPointRotateGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                            <uc:RotateGizmo.RenderTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="{Binding CurrentSelections.SelectedPathPoint.Rotation}"/>
                                </TransformGroup>
                            </uc:RotateGizmo.RenderTransform>
                        </uc:RotateGizmo>
                    </local:CenteringCanvas>
                    <local:CenteringCanvas>
                        <uc:RotateGizmo x:Name="LootRotateGizmo" Visibility="{Binding CurrentGizmoData.LootRotateGizmoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Canvas.Left="{Binding CurrentSelections.SelectedLoot.Coordinates.XPos}"
                            Canvas.Top="{Binding CurrentSelections.SelectedLoot.Coordinates.YPos}"
                            DragCommand="{Binding CurrentGizmoData.LootRotateGizmoMovedCommand}" RenderTransformOrigin="0.5,0.5">
                            <uc:RotateGizmo.RenderTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="{Binding CurrentSelections.SelectedLoot.Rotation}"/>
                                </TransformGroup>
                            </uc:RotateGizmo.RenderTransform>
                        </uc:RotateGizmo>
                    </local:CenteringCanvas>
                </Canvas>
            </ScrollViewer>
        </DockPanel>

    </Grid>


</Window>

    