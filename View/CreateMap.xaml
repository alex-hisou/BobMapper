<Window x:Class="BobMapper.View.CreateMap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BobMapper.View" xmlns:viewmodel="clr-namespace:BobMapper.ViewModel" 
        d:DataContext="{d:DesignInstance Type=viewmodel:CreateMapViewModel}"
        mc:Ignorable="d"
        Title="CreateMap" Height="288" Width="543" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="29*"/>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="44*"/>
            <RowDefinition Height="36*"/>
            <RowDefinition Height="62*"/>
            <RowDefinition Height="42*"/>
            <RowDefinition Height="29*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="59*"/>
            <ColumnDefinition Width="436*"/>
            <ColumnDefinition Width="40*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Width" HorizontalAlignment="Left" Margin="0,3,0,0" VerticalAlignment="Top" Height="31" Width="123" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2"/>
        <Button Content="Back" Grid.Column="1" RenderTransformOrigin="0.462,-3.341" Click="Button_Click" Grid.Row="5" Height="36" VerticalAlignment="Center" HorizontalAlignment="Left" Width="101"/>
        <Button Content="Create" Margin="347,3,0,2" Grid.Column="1" Grid.Row="5" Click="Button_Click_1"/>
        <TextBox Name="WidthBox" Grid.Column="1" Margin="10,0,371,0" TextWrapping="Wrap" 
                 Text="{Binding SizeX, UpdateSourceTrigger=LostFocus}" VerticalAlignment="Center" Grid.Row="2" Height="24"/>
        <Label Content="Height" HorizontalAlignment="Left" VerticalAlignment="Center" Height="30" Width="123" Grid.Column="1" Grid.Row="3"
               PreviewTextInput="TextBox_PreviewTextInput"/>
        <TextBox Name="HeightBox" Grid.Column="1" Margin="10,6,371,31" TextWrapping="Wrap" 
                 Text="{Binding SizeY, UpdateSourceTrigger=LostFocus}" Grid.Row="4"
                 PreviewTextInput="TextBox_PreviewTextInput"/>
        <ComboBox Name="TilesetCB" Grid.Column="1" Margin="309,5,10,5" Grid.Row="2"
                  ItemsSource="{Binding TilesetEnum}" SelectedValue="{Binding SelectedTileset}"/>
        <Label Content="Tileset" HorizontalAlignment="Left" Margin="319,3,0,0" VerticalAlignment="Top" Height="31" Width="123" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2"/>
        <Label Content="Chapter and level" HorizontalAlignment="Left" Margin="313,0,0,0" VerticalAlignment="Center" Height="30" Width="123" Grid.Column="1" Grid.Row="3"/>
    </Grid>
</Window>
