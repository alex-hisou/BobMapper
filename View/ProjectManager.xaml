<Window x:Class="BobMapper.ProjectManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BobMapper"
        mc:Ignorable="d" Background="DimGray" Foreground="White"
        
        Title="BobMapper" Height="450" Width="800" ResizeMode="CanMinimize">
    <Grid>
        <Button x:Name="NewMod" Content="Create new map"  Margin="0,90,0,0" VerticalAlignment="Top" Width="700" Height="70" Click="NewMod_Click" FontSize="22"/>
        <Button x:Name="LoadMod" Content="Load map" HorizontalAlignment="Center" Margin="0,177,0,0" VerticalAlignment="Top" Width="700" Height="70" Click="LoadMod_Click" FontSize="22"/>
        <Button x:Name="Prefrences" Content="Prefrences" HorizontalAlignment="Center" Margin="0,264,0,0" VerticalAlignment="Top" Width="700" Height="70" Click="Prefrences_Click" FontSize="22" IsEnabled="False"/>

    </Grid>
</Window>
