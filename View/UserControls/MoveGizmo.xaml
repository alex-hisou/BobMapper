<UserControl x:Class="BobMapper.View.UserControls.MoveGizmo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BobMapper.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="150">
    <Grid>
        <Canvas x:Name="VerticalHandle" MouseDown="Element_MouseLeftButtonDown" MouseMove="Element_MouseMove"
                MouseUp="Element_MouseLeftButtonUp" RenderTransformOrigin="0.5,0.5">
            <Line X1="20" Y1="10" X2="20" Y2="130" Stroke="Blue" StrokeThickness="5" HorizontalAlignment="Left" VerticalAlignment="Center" Width="40"/>
            <Line X1="15" Y1="15" X2="10" Y2="25" Stroke="Blue" StrokeThickness="5" Canvas.Left="11" Canvas.Top="104" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Line X1="25" Y1="15" X2="30" Y2="25" Stroke="Blue" StrokeThickness="5" Canvas.Left="-10" Canvas.Top="104" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Canvas>
        <Canvas x:Name="HorizontalHandle" MouseDown="Element_MouseLeftButtonDown" MouseMove="Element_MouseMove"
                MouseUp="Element_MouseLeftButtonUp">
            <Line X1="20" Y1="130" X2="130" Y2="130" Stroke="Red" StrokeThickness="5" Canvas.Left="2" Canvas.Top="-116"/>
            <Line X1="130" Y1="130" X2="120" Y2="125" Stroke="Red" StrokeThickness="5" Canvas.Left="1" Canvas.Top="-116" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Line X1="130" Y1="130" X2="120" Y2="135" Stroke="Red" StrokeThickness="5" Canvas.Left="1" Canvas.Top="-116" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Canvas>
        <Rectangle Fill="Yellow" Width="15" Height="15" Margin="13,6,122,129"/>
    </Grid>
</UserControl>
