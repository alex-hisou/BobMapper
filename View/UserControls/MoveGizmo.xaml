<UserControl x:Class="BobMapper.View.UserControls.MoveGizmo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BobMapper.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="150">
    <Grid>
        <Canvas x:Name="VerticalHandle" MouseDown="Element_MouseLeftButtonDown" MouseMove="Element_MouseMove"
                MouseUp="Element_MouseLeftButtonUp">
            <Line X1="20" Y1="10" X2="20" Y2="130" Stroke="Blue" StrokeThickness="5"/>
            <Line X1="20" Y1="10" X2="10" Y2="25" Stroke="Blue" StrokeThickness="5"/>
            <Line X1="20" Y1="10" X2="30" Y2="25" Stroke="Blue" StrokeThickness="5"/>
        </Canvas>
        <Canvas x:Name="HorizontalHandle">
            <Line X1="20" Y1="130" X2="130" Y2="130" Stroke="Red" StrokeThickness="5"/>
            <Line X1="130" Y1="130" X2="120" Y2="125" Stroke="Red" StrokeThickness="5"/>
            <Line X1="130" Y1="130" X2="120" Y2="135" Stroke="Red" StrokeThickness="5"/>
        </Canvas>
        <Rectangle Fill="Yellow" Margin="14,124,124,14"/>
    </Grid>
</UserControl>
